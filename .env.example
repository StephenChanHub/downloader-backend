# 数据库配置
# 内网地址: downloader-db-mysql.ns-lnn76r5i.svc:3306
DB_HOST=downloader-db-mysql.ns-lnn76r5i.svc
DB_PORT=3306
DB_USER=root
DB_PASS=your_db_password
DB_NAME=downloader

# JWT 密钥（管理员鉴权用，请更换为随机长字符串）
JWT_SECRET=change-me-to-a-random-string

# 管理员密码（明文，用于登录比对）
ADMIN_PASSWORD=admin123

# PDF 存储路径（生产环境默认 /home/devbox/project/storage/pdfs，本地开发可设为 ./storage/pdfs）
STORAGE_PATH=/home/devbox/project/storage/pdfs

# 前端地址（CORS 白名单）
FRONTEND_URL=https://wmrazineousa.sealosgzg.site

# 运行环境（development / production）
NODE_ENV=production
